# URL pública de la API
NEXT_PUBLIC_API_URL=http://localhost:3001/api

# Dominio raíz (para resolución de subdominios de tenant).
# Recomendado en dev: lvh.me (resuelve a 127.0.0.1 sin tocar /etc/hosts).
# Subdominios como acme.lvh.me:3000 funcionan automáticamente.
NEXT_PUBLIC_ROOT_DOMAIN=lvh.me:3000

# Secreto para firmar la cookie de sesión del web (Fase 5.2).
# Generar en producción con: openssl rand -base64 48
WEB_SESSION_SECRET=dev-insecure-session-secret-change-me
