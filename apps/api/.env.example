# App
NODE_ENV=development
PORT=3001
API_PREFIX=api

# CORS (orígenes permitidos separados por coma)
CORS_ORIGINS=http://localhost:3000

# Dominio raíz para resolver tenants por subdominio (sin esquema).
# En dev: localhost:3000 o lvh.me:3000. En prod: miapp.com
ROOT_DOMAIN=localhost:3000

# URL pública del API tal como la ve el browser. Se usa para construir URLs
# del mock storage (uploads de imágenes) cuando R2 no está configurado.
# Si no se setea, en dev cae a http://localhost:${PORT}/${API_PREFIX}.
# En producción es OBLIGATORIO si usás mock storage — sino el browser intenta
# subir a localhost del container y falla. Ej: https://api.tu-dominio.com/api
API_PUBLIC_URL=http://localhost:3001/api

# --- IA / LLM ---
# Master secret para encriptar las API keys de IA en DB (AES-256-GCM).
# OBLIGATORIO: sin esto el sistema rechaza guardar/leer keys.
# Generar con:  openssl rand -base64 32
# NO rotarlo sin re-encriptar las keys existentes (perderías las claves).
AI_KEYS_SECRET=

# La configuración real de provider/modelo/keys se gestiona desde el panel
# del super-admin (/platform-admin/ai-settings) y se persiste encriptada en
# la tabla platform_ai_settings. Las inmobiliarias eligen entre:
#   · DISABLED → plan no incluye IA
#   · PLATFORM → usa keys del super-admin (cobrable)
#   · OWN      → carga sus propias keys en /admin/settings/ai (no se cobra)
#
# Las siguientes vars solo se usan en CI/staging cuando NO hay row en DB:
#   AI_PROVIDER=mock          (default si nada está cargado)
AI_PROVIDER=mock

# --- RAG / Embeddings (Sprint 2) ---
# La búsqueda semántica de propiedades y el chatbot RAG usan pgvector +
# embeddings de OpenAI (text-embedding-3-small, 1536 dims). La key se carga
# desde /platform-admin/ai-settings → "embeddings" y se persiste encriptada.
#
# Importante: las keys de embeddings son SIEMPRE de plataforma (no por tenant).
# Razón: las propiedades indexadas y las queries de búsqueda deben usar el
# MISMO modelo/provider, sino los vectores no son comparables.
#
# Sin key cargada: el sistema cae a búsqueda keyword (ILIKE) y el chatbot
# responde sin contexto de propiedades. Los hooks de indexado en create/update
# de Property loguean warning y siguen el flujo normal (fail-safe).
#
# Requisitos de DB: Postgres con extensión pgvector. La imagen de prod
# (docker-compose.prod.yml) usa garapadev/postgres-postgis-pgvector:16-stable.
# En dev local, asegurate de tener pgvector disponible (la migración 3_pgvector
# ejecuta CREATE EXTENSION IF NOT EXISTS vector).

# Database
DATABASE_URL=postgresql://inmobiliaria:inmobiliaria_dev@localhost:5432/inmobiliaria?schema=public

# Redis
REDIS_URL=redis://localhost:6379

# JWT — generá secretos largos con: openssl rand -base64 48
JWT_ACCESS_SECRET=change-me-access
JWT_REFRESH_SECRET=change-me-refresh
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# Seed del primer super-admin (solo se usa por `pnpm prisma:seed`)
SUPER_ADMIN_EMAIL=admin@miapp.com
SUPER_ADMIN_PASSWORD=change-me-super-secret-12chars
SUPER_ADMIN_FIRST_NAME=Platform
SUPER_ADMIN_LAST_NAME=Admin

# Storage: Cloudflare R2 (S3-compatible).
# Si cualquiera de las 5 vars está vacía, la API usa el driver mock local
# (uploads bajo ./storage/uploads servidos por el backend). Útil para dev sin R2.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=inmobiliaria-media
# Dominio público donde sirve el bucket (ej. https://cdn.miapp.com). Sin slash final.
R2_PUBLIC_URL=
