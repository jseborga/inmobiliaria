# App
NODE_ENV=development
PORT=3001
API_PREFIX=api

# CORS (orígenes permitidos separados por coma)
CORS_ORIGINS=http://localhost:3000

# Database
DATABASE_URL=postgresql://inmobiliaria:inmobiliaria_dev@localhost:5432/inmobiliaria?schema=public

# Redis
REDIS_URL=redis://localhost:6379

# JWT (se usarán en Fase 3)
JWT_ACCESS_SECRET=change-me-access
JWT_REFRESH_SECRET=change-me-refresh
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# Storage (se usará en Fase 4)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=inmobiliaria-media
R2_PUBLIC_URL=
