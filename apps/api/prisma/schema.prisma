// Prisma schema — Fase 6: + Lead, LeadActivity.

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [postgis]
}

enum UserRole {
  OWNER
  ADMIN
  AGENT
}

enum TenantStatus {
  ACTIVE
  SUSPENDED
}

enum TenantPlan {
  FREE
  PRO
}

enum UserStatus {
  ACTIVE
  DISABLED
}

enum PlatformAdminStatus {
  ACTIVE
  DISABLED
}

enum PropertyOperation {
  SALE
  RENT
  ANTICRETICO
}

enum PropertyStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum PropertyType {
  HOUSE
  APARTMENT
  LAND
  OFFICE
  COMMERCIAL
  OTHER
}

enum Currency {
  BOB
  USD
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  CONVERTED
  LOST
}

enum LeadSource {
  WEB
  WHATSAPP
  PHONE
  REFERRAL
  OTHER
}

enum LeadActivityKind {
  NOTE
  CALL
  EMAIL
  WHATSAPP
  MEETING
  STATUS_CHANGE
  ASSIGNMENT
  CREATED
}

/// Empresa inmobiliaria (tenant).
model Tenant {
  id        String       @id @default(cuid())
  slug      String       @unique
  name      String
  logoUrl   String?      @map("logo_url")
  phone     String?
  email     String?
  address   String?
  city      String?
  status    TenantStatus @default(ACTIVE)
  plan      TenantPlan   @default(FREE)
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")

  users          User[]
  refreshTokens  RefreshToken[]
  properties     Property[]
  propertyImages PropertyImage[]
  leads          Lead[]
  leadActivities LeadActivity[]

  @@map("tenants")
}

/// Usuario perteneciente a un tenant (OWNER / ADMIN / AGENT).
model User {
  id           String     @id @default(cuid())
  tenantId     String     @map("tenant_id")
  email        String
  passwordHash String     @map("password_hash")
  firstName    String     @map("first_name")
  lastName     String     @map("last_name")
  phone        String?
  avatarUrl    String?    @map("avatar_url")
  role         UserRole   @default(AGENT)
  status       UserStatus @default(ACTIVE)
  lastLoginAt  DateTime?  @map("last_login_at")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  tenant            Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  refreshTokens     RefreshToken[]
  createdProperties Property[]     @relation("PropertyCreatedBy")
  assignedLeads     Lead[]         @relation("LeadAssignedTo")
  leadActivities    LeadActivity[]

  // Email único dentro de un mismo tenant (el mismo email puede existir en tenants distintos)
  @@unique([tenantId, email])
  @@index([tenantId])
  @@map("users")
}

/// Refresh tokens almacenados con hash para rotación y revocación.
model RefreshToken {
  id        String    @id @default(cuid())
  tenantId  String    @map("tenant_id")
  userId    String    @map("user_id")
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  userAgent String?   @map("user_agent")
  ip        String?
  createdAt DateTime  @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tenantId])
  @@map("refresh_tokens")
}

/// Administrador de plataforma (super-admin global, no pertenece a ningún tenant).
/// Solo este rol puede crear/suspender tenants y hacer onboarding de inmobiliarias.
model PlatformAdmin {
  id           String              @id @default(cuid())
  email        String              @unique
  passwordHash String              @map("password_hash")
  firstName    String              @map("first_name")
  lastName     String              @map("last_name")
  status       PlatformAdminStatus @default(ACTIVE)
  lastLoginAt  DateTime?           @map("last_login_at")
  createdAt    DateTime            @default(now()) @map("created_at")
  updatedAt    DateTime            @updatedAt @map("updated_at")

  refreshTokens PlatformRefreshToken[]

  @@map("platform_admins")
}

/// Refresh tokens de platform admin (separados de los de tenant users).
model PlatformRefreshToken {
  id        String    @id @default(cuid())
  adminId   String    @map("admin_id")
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  userAgent String?   @map("user_agent")
  ip        String?
  createdAt DateTime  @default(now()) @map("created_at")

  admin PlatformAdmin @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@index([adminId])
  @@map("platform_refresh_tokens")
}

/// Propiedad inmobiliaria (casa, depto, terreno, etc.) publicable en el marketplace.
/// La columna `location` (PostGIS geography(Point,4326)) se maneja vía SQL raw
/// desde el servicio; Prisma la ve como Unsupported y no la expone en el cliente.
model Property {
  id            String                                 @id @default(cuid())
  tenantId      String                                 @map("tenant_id")
  slug          String
  title         String
  description   String?
  operation     PropertyOperation
  type          PropertyType
  status        PropertyStatus                         @default(DRAFT)
  price         Decimal                                @db.Decimal(14, 2)
  currency      Currency                               @default(BOB)
  areaSqm       Decimal?                               @map("area_sqm") @db.Decimal(10, 2)
  bedrooms      Int?
  bathrooms     Int?
  parkingSpaces Int?                                   @map("parking_spaces")
  city          String?
  zone          String?
  address       String?
  latitude      Decimal?                               @db.Decimal(10, 7)
  longitude     Decimal?                               @db.Decimal(10, 7)
  /// PostGIS geography(Point, 4326). Mantenida sincronizada con lat/lng vía SQL.
  location      Unsupported("geography(Point, 4326)")?
  createdById   String?                                @map("created_by_id")
  publishedAt   DateTime?                              @map("published_at")
  archivedAt    DateTime?                              @map("archived_at")
  createdAt     DateTime                               @default(now()) @map("created_at")
  updatedAt     DateTime                               @updatedAt @map("updated_at")

  tenant    Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdBy User?           @relation("PropertyCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  images    PropertyImage[]
  leads     Lead[]

  // Slug único dentro del tenant (para URLs tipo /p/{slug})
  @@unique([tenantId, slug])
  @@index([tenantId, status])
  @@index([tenantId, operation, type])
  @@index([tenantId, city])
  @@map("properties")
}

/// Imágenes de una propiedad almacenadas en R2 (Cloudflare) vía upload presigned.
model PropertyImage {
  id         String   @id @default(cuid())
  tenantId   String   @map("tenant_id")
  propertyId String   @map("property_id")
  r2Key      String   @unique @map("r2_key")
  publicUrl  String   @map("public_url")
  order      Int      @default(0)
  width      Int?
  height     Int?
  createdAt  DateTime @default(now()) @map("created_at")

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId, order])
  @@index([tenantId])
  @@map("property_images")
}

/// Lead / contacto comercial recibido vía marketplace o capturado manualmente.
/// Puede estar ligado a una propiedad específica o ser un contacto general
/// con la inmobiliaria.
model Lead {
  id               String     @id @default(cuid())
  tenantId         String     @map("tenant_id")
  propertyId       String?    @map("property_id")
  source           LeadSource @default(WEB)
  status           LeadStatus @default(NEW)
  firstName        String     @map("first_name")
  lastName         String?    @map("last_name")
  email            String?
  phone            String?
  message          String?
  /// Agente al que se le asignó el seguimiento. Null = sin asignar.
  assignedUserId   String?    @map("assigned_user_id")
  /// IP origen del form público (para anti-spam / auditoría).
  sourceIp         String?    @map("source_ip")
  /// User-Agent del form público.
  sourceUserAgent  String?    @map("source_user_agent")
  /// URL de referrer cuando el lead viene del marketplace.
  sourceReferrer   String?    @map("source_referrer")
  lastContactedAt  DateTime?  @map("last_contacted_at")
  createdAt        DateTime   @default(now()) @map("created_at")
  updatedAt        DateTime   @updatedAt @map("updated_at")

  tenant       Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  property     Property?      @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  assignedTo   User?          @relation("LeadAssignedTo", fields: [assignedUserId], references: [id], onDelete: SetNull)
  activities   LeadActivity[]

  @@index([tenantId, status])
  @@index([tenantId, createdAt])
  @@index([tenantId, assignedUserId])
  @@index([propertyId])
  @@map("leads")
}

/// Log de interacciones con un lead (notas, llamadas, cambios de status, etc.).
/// El timeline se reconstruye ordenando por createdAt.
model LeadActivity {
  id        String           @id @default(cuid())
  tenantId  String           @map("tenant_id")
  leadId    String           @map("lead_id")
  /// Usuario que registró la actividad. Null = generada por el sistema
  /// (creación automática desde formulario público, cambios de status, etc.).
  userId    String?          @map("user_id")
  kind      LeadActivityKind
  body      String?
  /// Metadata opcional en JSON: ej. {from:"NEW",to:"CONTACTED"} para STATUS_CHANGE.
  metadata  Json?
  createdAt DateTime         @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  lead   Lead   @relation(fields: [leadId], references: [id], onDelete: Cascade)
  user   User?  @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([leadId, createdAt])
  @@index([tenantId])
  @@map("lead_activities")
}
