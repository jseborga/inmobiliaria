// Prisma schema — Fase 6: + Lead, LeadActivity.

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [postgis]
}

enum UserRole {
  OWNER
  ADMIN
  AGENT
}

enum TenantStatus {
  ACTIVE
  SUSPENDED
}

enum TenantPlan {
  FREE
  PRO
}

enum UserStatus {
  ACTIVE
  DISABLED
}

enum PlatformAdminStatus {
  ACTIVE
  DISABLED
}

enum PropertyOperation {
  SALE
  RENT
  ANTICRETICO
}

enum PropertyStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum PropertyType {
  HOUSE
  APARTMENT
  LAND
  OFFICE
  COMMERCIAL
  OTHER
}

enum Currency {
  BOB
  USD
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  CONVERTED
  LOST
}

enum LeadSource {
  WEB
  WHATSAPP
  PHONE
  REFERRAL
  OTHER
}

enum LeadActivityKind {
  NOTE
  CALL
  EMAIL
  WHATSAPP
  MEETING
  STATUS_CHANGE
  ASSIGNMENT
  CREATED
}

/// Modo de IA por inmobiliaria.
/// - DISABLED: el plan no incluye IA (default plan FREE).
/// - PLATFORM: usa las keys del super-admin global. Se contabiliza para billing.
/// - OWN:      la inmobiliaria carga sus propias keys, no se cobra.
enum TenantAIMode {
  DISABLED
  PLATFORM
  OWN
}

enum AIFeature {
  DESCRIPTION
  CHATBOT
  EMBEDDINGS
}

enum VisitStatus {
  REQUESTED   // visitante propuso fecha/hora, falta confirmación del agente
  CONFIRMED   // agente confirmó la visita
  COMPLETED   // se realizó (admin la marca después)
  CANCELLED   // canceló alguien (visitante o agente)
  NO_SHOW     // visitante no apareció
}

enum OtpContext {
  VISIT_BOOKING
  // futuros: ACCOUNT_LOGIN, etc.
}

/// Empresa inmobiliaria (tenant).
model Tenant {
  id        String       @id @default(cuid())
  slug      String       @unique
  name      String
  logoUrl   String?      @map("logo_url")
  phone     String?
  email     String?
  address   String?
  city      String?
  status    TenantStatus @default(ACTIVE)
  plan      TenantPlan   @default(FREE)
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")

  users          User[]
  refreshTokens  RefreshToken[]
  properties     Property[]
  propertyImages PropertyImage[]
  leads          Lead[]
  leadActivities LeadActivity[]
  aiSettings     TenantAISettings?
  aiUsage        AIUsage[]
  visits         Visit[]
  whatsapp       WhatsappIntegration?

  @@map("tenants")
}

/// Usuario perteneciente a un tenant (OWNER / ADMIN / AGENT).
model User {
  id           String     @id @default(cuid())
  tenantId     String     @map("tenant_id")
  email        String
  passwordHash String     @map("password_hash")
  firstName    String     @map("first_name")
  lastName     String     @map("last_name")
  phone        String?
  avatarUrl    String?    @map("avatar_url")
  role         UserRole   @default(AGENT)
  status       UserStatus @default(ACTIVE)
  lastLoginAt  DateTime?  @map("last_login_at")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  tenant            Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  refreshTokens     RefreshToken[]
  createdProperties Property[]     @relation("PropertyCreatedBy")
  assignedLeads     Lead[]         @relation("LeadAssignedTo")
  assignedVisits    Visit[]        @relation("VisitAssignedTo")
  leadActivities    LeadActivity[]

  // Email único dentro de un mismo tenant (el mismo email puede existir en tenants distintos)
  @@unique([tenantId, email])
  @@index([tenantId])
  @@map("users")
}

/// Refresh tokens almacenados con hash para rotación y revocación.
model RefreshToken {
  id        String    @id @default(cuid())
  tenantId  String    @map("tenant_id")
  userId    String    @map("user_id")
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  userAgent String?   @map("user_agent")
  ip        String?
  createdAt DateTime  @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tenantId])
  @@map("refresh_tokens")
}

/// Administrador de plataforma (super-admin global, no pertenece a ningún tenant).
/// Solo este rol puede crear/suspender tenants y hacer onboarding de inmobiliarias.
model PlatformAdmin {
  id           String              @id @default(cuid())
  email        String              @unique
  passwordHash String              @map("password_hash")
  firstName    String              @map("first_name")
  lastName     String              @map("last_name")
  status       PlatformAdminStatus @default(ACTIVE)
  lastLoginAt  DateTime?           @map("last_login_at")
  createdAt    DateTime            @default(now()) @map("created_at")
  updatedAt    DateTime            @updatedAt @map("updated_at")

  refreshTokens PlatformRefreshToken[]

  @@map("platform_admins")
}

/// Refresh tokens de platform admin (separados de los de tenant users).
model PlatformRefreshToken {
  id        String    @id @default(cuid())
  adminId   String    @map("admin_id")
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  userAgent String?   @map("user_agent")
  ip        String?
  createdAt DateTime  @default(now()) @map("created_at")

  admin PlatformAdmin @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@index([adminId])
  @@map("platform_refresh_tokens")
}

/// Propiedad inmobiliaria (casa, depto, terreno, etc.) publicable en el marketplace.
/// La columna `location` (PostGIS geography(Point,4326)) se maneja vía SQL raw
/// desde el servicio; Prisma la ve como Unsupported y no la expone en el cliente.
model Property {
  id            String                                 @id @default(cuid())
  tenantId      String                                 @map("tenant_id")
  slug          String
  title         String
  description   String?
  operation     PropertyOperation
  type          PropertyType
  status        PropertyStatus                         @default(DRAFT)
  price         Decimal                                @db.Decimal(14, 2)
  currency      Currency                               @default(BOB)
  areaSqm       Decimal?                               @map("area_sqm") @db.Decimal(10, 2)
  bedrooms      Int?
  bathrooms     Int?
  parkingSpaces Int?                                   @map("parking_spaces")
  city          String?
  zone          String?
  address       String?
  latitude      Decimal?                               @db.Decimal(10, 7)
  longitude     Decimal?                               @db.Decimal(10, 7)
  /// PostGIS geography(Point, 4326). Mantenida sincronizada con lat/lng vía SQL.
  location      Unsupported("geography(Point, 4326)")?
  /// URL externa de video (YouTube, Vimeo, etc.). Embed-friendly.
  videoUrl      String?                                @map("video_url")
  /// URL externa de tour 360 (Matterport, Kuula, etc.).
  tour360Url    String?                                @map("tour_360_url")
  /// pgvector(1536) con el embedding semántico de la propiedad. Lo gestiona
  /// PropertyIndexerService cuando cambian title/description/city/zone/type/operation.
  embedding     Unsupported("vector(1536)")?
  embeddingModel String?                               @map("embedding_model")
  embeddedAt    DateTime?                              @map("embedded_at")
  createdById   String?                                @map("created_by_id")
  publishedAt   DateTime?                              @map("published_at")
  archivedAt    DateTime?                              @map("archived_at")
  createdAt     DateTime                               @default(now()) @map("created_at")
  updatedAt     DateTime                               @updatedAt @map("updated_at")

  tenant    Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdBy User?           @relation("PropertyCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  images    PropertyImage[]
  leads     Lead[]
  visits    Visit[]

  // Slug único dentro del tenant (para URLs tipo /p/{slug})
  @@unique([tenantId, slug])
  @@index([tenantId, status])
  @@index([tenantId, operation, type])
  @@index([tenantId, city])
  @@map("properties")
}

/// Imágenes de una propiedad almacenadas en R2 (Cloudflare) vía upload presigned.
model PropertyImage {
  id         String   @id @default(cuid())
  tenantId   String   @map("tenant_id")
  propertyId String   @map("property_id")
  r2Key      String   @unique @map("r2_key")
  publicUrl  String   @map("public_url")
  order      Int      @default(0)
  width      Int?
  height     Int?
  createdAt  DateTime @default(now()) @map("created_at")

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId, order])
  @@index([tenantId])
  @@map("property_images")
}

/// Lead / contacto comercial recibido vía marketplace o capturado manualmente.
/// Puede estar ligado a una propiedad específica o ser un contacto general
/// con la inmobiliaria.
model Lead {
  id               String     @id @default(cuid())
  tenantId         String     @map("tenant_id")
  propertyId       String?    @map("property_id")
  source           LeadSource @default(WEB)
  status           LeadStatus @default(NEW)
  firstName        String     @map("first_name")
  lastName         String?    @map("last_name")
  email            String?
  phone            String?
  message          String?
  /// Agente al que se le asignó el seguimiento. Null = sin asignar.
  assignedUserId   String?    @map("assigned_user_id")
  /// IP origen del form público (para anti-spam / auditoría).
  sourceIp         String?    @map("source_ip")
  /// User-Agent del form público.
  sourceUserAgent  String?    @map("source_user_agent")
  /// URL de referrer cuando el lead viene del marketplace.
  sourceReferrer   String?    @map("source_referrer")
  lastContactedAt  DateTime?  @map("last_contacted_at")
  createdAt        DateTime   @default(now()) @map("created_at")
  updatedAt        DateTime   @updatedAt @map("updated_at")

  tenant       Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  property     Property?      @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  assignedTo   User?          @relation("LeadAssignedTo", fields: [assignedUserId], references: [id], onDelete: SetNull)
  activities   LeadActivity[]
  visits       Visit[]

  @@index([tenantId, status])
  @@index([tenantId, createdAt])
  @@index([tenantId, assignedUserId])
  @@index([propertyId])
  @@map("leads")
}

/// Log de interacciones con un lead (notas, llamadas, cambios de status, etc.).
/// El timeline se reconstruye ordenando por createdAt.
model LeadActivity {
  id        String           @id @default(cuid())
  tenantId  String           @map("tenant_id")
  leadId    String           @map("lead_id")
  /// Usuario que registró la actividad. Null = generada por el sistema
  /// (creación automática desde formulario público, cambios de status, etc.).
  userId    String?          @map("user_id")
  kind      LeadActivityKind
  body      String?
  /// Metadata opcional en JSON: ej. {from:"NEW",to:"CONTACTED"} para STATUS_CHANGE.
  metadata  Json?
  createdAt DateTime         @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  lead   Lead   @relation(fields: [leadId], references: [id], onDelete: Cascade)
  user   User?  @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([leadId, createdAt])
  @@index([tenantId])
  @@map("lead_activities")
}

/// Configuración global de IA (singleton). Solo el super-admin puede editar.
/// Las keys quedan encriptadas en DB con AES-256-GCM (master en env AI_KEYS_SECRET).
model PlatformAISettings {
  id              String   @id @default("singleton")
  defaultProvider String?  @map("default_provider")
  defaultModel    String?  @map("default_model")
  /// Keys master usadas por tenants con aiMode=PLATFORM. Encriptadas.
  claudeKeyEnc       String? @map("claude_key_enc")
  openaiKeyEnc       String? @map("openai_key_enc")
  openrouterKeyEnc   String? @map("openrouter_key_enc")
  /// Embeddings (RAG). Default openai/text-embedding-3-small.
  embeddingsProvider String? @map("embeddings_provider")
  embeddingsModel    String? @map("embeddings_model")
  embeddingsKeyEnc   String? @map("embeddings_key_enc")
  updatedAt          DateTime @updatedAt @map("updated_at")

  @@map("platform_ai_settings")
}

/// Configuración de IA por inmobiliaria.
/// 1:1 con Tenant. Si no existe, el resolver asume defaults según el plan
/// (FREE → DISABLED, PRO → PLATFORM).
model TenantAISettings {
  tenantId           String       @id @map("tenant_id")
  mode               TenantAIMode @default(DISABLED)
  /// Override del provider/modelo. Null usa el default del PlatformAISettings.
  provider           String?
  model              String?
  /// Keys propias del tenant (solo cuando mode=OWN). Encriptadas.
  claudeKeyEnc       String?      @map("claude_key_enc")
  openaiKeyEnc       String?      @map("openai_key_enc")
  openrouterKeyEnc   String?      @map("openrouter_key_enc")
  /// Cuota mensual (solo aplica a mode=PLATFORM para billing). Null = sin tope.
  monthlyTokenLimit  Int?         @map("monthly_token_limit")
  monthlyTokenUsed   Int          @default(0) @map("monthly_token_used")
  monthlyResetAt     DateTime     @default(now()) @map("monthly_reset_at")
  updatedAt          DateTime     @updatedAt @map("updated_at")

  tenant             Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("tenant_ai_settings")
}

/// Log de cada llamada a IA. Sirve para reportes de uso y billing.
model AIUsage {
  id           String    @id @default(cuid())
  tenantId     String    @map("tenant_id")
  feature      AIFeature
  provider     String
  model        String
  inputTokens  Int       @default(0) @map("input_tokens")
  outputTokens Int       @default(0) @map("output_tokens")
  /// Si la key vino del super-admin (mode=PLATFORM) → true. Si fue del tenant → false.
  /// Solo las "billable=true" se cuentan para el cobro mensual.
  billable     Boolean   @default(false)
  createdAt    DateTime  @default(now()) @map("created_at")

  tenant       Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, createdAt])
  @@index([tenantId, billable, createdAt])
  @@map("ai_usage")
}

/// Visita presencial agendada por un visitante público a una propiedad.
/// Flujo: REQUESTED (booking) → CONFIRMED (agente acepta) → COMPLETED/NO_SHOW.
/// El número de teléfono se valida con OTP por WhatsApp antes de crear la visita.
model Visit {
  id              String      @id @default(cuid())
  tenantId        String      @map("tenant_id")
  propertyId      String      @map("property_id")
  /// Agente al que se le asigna (default: createdBy de la propiedad o OWNER del tenant).
  assignedUserId  String?     @map("assigned_user_id")
  scheduledAt     DateTime    @map("scheduled_at")
  durationMinutes Int         @default(30) @map("duration_minutes")
  status          VisitStatus @default(REQUESTED)
  visitorName     String      @map("visitor_name")
  visitorPhone    String      @map("visitor_phone")
  visitorEmail    String?     @map("visitor_email")
  /// Mensaje opcional del visitante.
  notes           String?
  /// Cuándo se validó el OTP del teléfono. Si null, la visita se creó manualmente
  /// desde admin (sin verificación de teléfono).
  phoneVerifiedAt DateTime?   @map("phone_verified_at")
  cancelReason    String?     @map("cancel_reason")
  /// Si la visita fue convertida en lead, queda linkeada acá.
  leadId          String?     @map("lead_id")
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")

  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  assignedTo User?    @relation("VisitAssignedTo", fields: [assignedUserId], references: [id], onDelete: SetNull)
  lead       Lead?    @relation(fields: [leadId], references: [id], onDelete: SetNull)

  @@index([tenantId, status, scheduledAt])
  @@index([tenantId, scheduledAt])
  @@index([assignedUserId, scheduledAt])
  @@index([propertyId])
  @@map("visits")
}

/// Códigos OTP enviados por WhatsApp para validar teléfono antes de booking.
/// Uso: el código se hashea con SHA-256 y se almacena. Verify hace constant-time
/// compare. Expiración 10 min, máx 5 intentos por código.
model PhoneOtp {
  id          String     @id @default(cuid())
  /// Teléfono normalizado (E.164, ej: +59177...).
  phone       String
  context     OtpContext @default(VISIT_BOOKING)
  codeHash    String     @map("code_hash")
  expiresAt   DateTime   @map("expires_at")
  consumedAt  DateTime?  @map("consumed_at")
  attempts    Int        @default(0)
  /// Tenant que originó la solicitud (para rate-limiting + auditoría).
  tenantId    String?    @map("tenant_id")
  /// True si fue creado en testMode — no se mandó WhatsApp real.
  testMode    Boolean    @default(false) @map("test_mode")
  createdAt   DateTime   @default(now()) @map("created_at")

  @@index([phone, context, createdAt])
  @@index([expiresAt])
  @@map("phone_otps")
}

/// Configuración de Evolution API por tenant. Se usa para mandar WhatsApp
/// (OTPs por ahora; en Sprint 4 también el bot conversacional).
/// La apiKey se almacena encriptada (mismo cipher que las API keys de IA,
/// AI_KEYS_SECRET).
model WhatsappIntegration {
  tenantId   String   @id @map("tenant_id")
  /// URL base de la instancia Evolution. Ej: https://evo.tu-dominio.com
  baseUrl    String?  @map("base_url")
  /// Nombre de la instancia configurada en Evolution.
  instance   String?
  /// API key encriptada (apikey global o instance-token de Evolution).
  apiKeyEnc  String?  @map("api_key_enc")
  /// Cuando true, el sistema NO manda WhatsApp real — los mensajes se loggean.
  /// Útil para QA sin gastar la sesión de WhatsApp Web.
  testMode   Boolean  @default(true) @map("test_mode")
  /// Si la integración está habilitada (puede estar configurada pero pausada).
  enabled    Boolean  @default(false)
  updatedAt  DateTime @updatedAt @map("updated_at")

  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("whatsapp_integrations")
}
