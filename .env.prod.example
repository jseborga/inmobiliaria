# Variables para `docker compose -f docker-compose.prod.yml`.
# Copiar a `.env.prod` y editar. NO commitear el .env.prod real.
#
#   cp .env.prod.example .env.prod
#   # editar secretos
#   docker compose -f docker-compose.prod.yml --env-file .env.prod up -d --build

# --- Postgres ---
POSTGRES_DB=inmobiliaria
POSTGRES_USER=inmobiliaria
# Generar: openssl rand -base64 32
POSTGRES_PASSWORD=change-me-strong-password

# --- Dominios + CORS ---
# Para Easypanel/prod usar HTTPS con tus dominios reales.
ROOT_DOMAIN=tu-dominio.com
CORS_ORIGINS=https://app.tu-dominio.com,https://tu-dominio.com
NEXT_PUBLIC_API_URL=https://api.tu-dominio.com/api
NEXT_PUBLIC_ROOT_DOMAIN=tu-dominio.com
# URL que usa el SERVER-side del web (Server Components, route handlers)
# para hablar con el API. Conviene la red interna de docker/Easypanel para
# no salir al DNS público + TLS y evitar hairpin NAT. Si no se setea cae
# a NEXT_PUBLIC_API_URL.
#   - compose:   http://api:3001/api
#   - Easypanel: http://<proyecto>_<servicio-api>:3001/api
INTERNAL_API_URL=http://api:3001/api

# --- JWT (NUNCA reusar entre envs) ---
# Generar cada uno: openssl rand -base64 48
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# --- Super-admin inicial (creado por el seed la primera vez) ---
SUPER_ADMIN_EMAIL=admin@tu-dominio.com
# Mínimo 12 caracteres, mayúsculas + números + símbolos.
SUPER_ADMIN_PASSWORD=change-me-super-admin
SUPER_ADMIN_FIRST_NAME=Platform
SUPER_ADMIN_LAST_NAME=Admin

# --- Web ---
# Generar: openssl rand -base64 48
WEB_SESSION_SECRET=change-me-web-session

# --- Storage (Cloudflare R2). Dejar vacío para usar mock en disco. ---
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_URL=

# --- Puertos expuestos del host (cambiá si tenés conflicto) ---
API_PORT=3001
WEB_PORT=3000

# --- Escape hatch: cookies sin Secure ---
# SOLO si deployás en HTTP plano (sin TLS). En Easypanel con Caddy o Cloudflare
# por delante (lo normal) dejalo vacío. Activarlo en prod sobre HTTPS hace que
# las cookies viajen por canales no cifrados — riesgo de MITM.
# COOKIE_INSECURE=1

# --- Observabilidad (Fase 7.1) ---
# Sentry DSN: si está, se reportan errores 5xx + uncaught a Sentry.
# Dejá vacío para deshabilitar.
# SENTRY_DSN=https://...@sentry.io/...
# Para el bundle del browser exponemos NEXT_PUBLIC_SENTRY_DSN (puede ser
# distinto, idealmente con permisos solo de envío).
# NEXT_PUBLIC_SENTRY_DSN=https://...@sentry.io/...
# Tracing/perf samples [0..1]. Default 0 para no inflar la cuota.
# SENTRY_TRACES_SAMPLE_RATE=0.1

# Logs estructurados. Default `info` en prod, `debug` en dev.
# LOG_LEVEL=info

# Inyectado idealmente por tu CI o build. Aparece en /api/health y en
# Sentry como `release`, para correlacionar deploys con errores.
# GIT_SHA=abc1234
